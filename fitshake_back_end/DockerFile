# Estágio 1: Build da aplicação
FROM maven:3.9.6-eclipse-temurin-17 AS build
WORKDIR /app

# Copia apenas o conteúdo da pasta do backend para dentro do container
# Isso evita copiar arquivos desnecessários do front-end para o build do Java
COPY fitshake_back_end /app

# Como copiamos o conteúdo DA pasta direto para /app, o pom.xml estará na raiz (/app)
RUN mvn clean package -DskipTests

# Estágio 2: Execução do Java
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app

EXPOSE 8080

# Copia o JAR gerado no estágio anterior
COPY --from=build /app/target/*.jar app.jar

ENTRYPOINT ["java", "-jar", "app.jar"]